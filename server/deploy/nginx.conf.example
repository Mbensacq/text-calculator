# nginx reverse proxy for the sync API — the important part for real-time is
# turning OFF buffering so Server-Sent Events reach the browser immediately.
#
# Two common layouts:
#   A) API on its own subdomain  (api.mon-domaine.com)  → recommended
#   B) API under a path of the app domain (mon-domaine.com/sync/ …)
#
# HTTPS is assumed via Let's Encrypt (certbot). Infomaniak VPS: `sudo certbot --nginx`.

# ---- A) Dedicated subdomain ------------------------------------------------
server {
    listen 443 ssl http2;
    server_name api.mon-domaine.com;

    # ssl_certificate ... (managed by certbot)

    location / {
        proxy_pass http://127.0.0.1:8090;
        proxy_http_version 1.1;

        # Essential for SSE:
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# ---- B) Same domain, API under /sync/ --------------------------------------
# In the app you would then set the sync URL to https://mon-domaine.com/sync
# and the routes become /sync/ws/<ws>/notes.json — adjust proxy_pass to strip
# the prefix:
#
# location /sync/ {
#     proxy_pass http://127.0.0.1:8090/;
#     proxy_http_version 1.1;
#     proxy_set_header Connection '';
#     proxy_buffering off;
#     proxy_read_timeout 3600s;
#     proxy_set_header Host $host;
# }
