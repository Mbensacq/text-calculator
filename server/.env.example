# ─────────────────────────────────────────────────────────────────────────
# Serveur de synchronisation Text Calculator — configuration
#
# 1. Copiez ce fichier :   cp .env.example .env
# 2. Renseignez vos valeurs ci-dessous.
# 3. Le service systemd le charge via « EnvironmentFile » (voir
#    deploy/text-calculator-sync.service). NE COMMITTEZ JAMAIS le .env réel —
#    il est ignoré par git ; seul ce .env.example est versionné.
#
# Format systemd : une paire CLE=valeur par ligne, sans guillemets ni « export ».
# ─────────────────────────────────────────────────────────────────────────

# ── Réseau ────────────────────────────────────────────────────────────────
PORT=8090
# 127.0.0.1 si un nginx assure le TLS devant le service ; 0.0.0.0 pour exposer
# directement (déconseillé sans reverse-proxy).
HOST=127.0.0.1
# Origine autorisée pour le CORS = l'URL du site. « * » en test uniquement.
CORS_ORIGIN=https://calc.mon-domaine.com
# Intervalle des battements de cœur SSE (ms). Laissez la valeur par défaut.
HEARTBEAT_MS=25000
# Taille maximale d'une note reçue (octets). 12 Mo par défaut — assez pour
# plusieurs images (plafonnées à ~2,6 Mo côté client) une fois chiffrées.
# MAX_BODY=12582912

# ── Sécurité ──────────────────────────────────────────────────────────────
# Jeton partagé exigé en « ?auth= » pour lire/écrire. FORTEMENT recommandé si
# l'endpoint est public. Générez une longue chaîne aléatoire.
SYNC_TOKEN=

# ── Servir aussi le site depuis ce serveur (origine unique) ───────────────
# Optionnel : chemin absolu vers le dépôt cloné pour que le serveur serve
# aussi index.html/src/styles. Sinon, laissez nginx servir les fichiers.
# SERVE_STATIC=/var/www/text-calculator

# ── Stockage ──────────────────────────────────────────────────────────────
# Par défaut : un simple fichier JSON (aucune base de données requise).
DATA_FILE=/var/www/text-calculator/server/data/notes.json

# OU une base SQL. Dès qu'un des réglages ci-dessous est défini, DATA_FILE est
# ignoré. Décommentez la ligne qui vous concerne.
#
#   MySQL / MariaDB (typique chez Infomaniak) :
# DATABASE_URL=mysql://utilisateur:motdepasse@hote:3306/nom_base
#   PostgreSQL :
# DATABASE_URL=postgres://utilisateur:motdepasse@hote:5432/nom_base
#
#   …ou en pièces détachées (au lieu de DATABASE_URL) :
# DB_CLIENT=mysql            # mysql | postgres
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
#   TLS (souvent requis pour une base managée) :
# DB_SSL=1
# DB_SSL_INSECURE=0          # 1 pour ignorer la vérification du certificat
